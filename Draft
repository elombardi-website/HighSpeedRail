function stationPopup(s) {
  const servesHtml = s.serves.map(l=>`<div class="pu-row"><span class="k" style="color:#888">Serves</span><span class="v sm">${l}</span></div>`).join('');
  const timesHtml  = s.times.map(([d,t,v])=>tRow(d,t,v)).join('');
  const tierBadge  = s.tier===4
    ? bdg('Tier 4 · '+s.connections+' Connections','#fef3c7','#92400e','#fcd34d')
    : s.tier===3
    ? bdg('Tier 3 · '+s.connections+' Connections','#fee2e2','#991b1b','#fca5a5')
    : bdg('Regional · '+s.connections+' Connection'+(s.connections!==1?'s':''),'#f3f4f6','#374151','#d1d5db');
  const propFlag   = s.proposed ? `<span class="pu-proposed">⚠ Proposed New Station</span><br>` : '';
  const timeLabel  = s.chatham  ? '◎ Regional journey times' : '⚡ Express journey times';

  return `
    <div class="pu-title">${s.name}</div>
    <div class="pu-sub">${s.sub}</div>
    ${propFlag}
    ${sec('Connections')}${servesHtml}
    ${note(s.note)}
    ${sec(timeLabel)}${timesHtml}
    <div style="margin-top:10px">${tierBadge}</div>`;
}

stations.forEach(s => {
  const col = s.tier===4?'#d4a017':s.tier===3?'#1d6fa4':'#6b7280';
  L.circleMarker(s.coords,{radius:s.r+4,fillColor:col,color:'white',weight:0,opacity:0,fillOpacity:0.18}).addTo(layers.ph1);
  const mOpts={radius:s.r,fillColor:col,color:'#fff',weight:2.5,opacity:1,fillOpacity:1};
  if(s.proposed){mOpts.color='#854d0e';mOpts.dashArray='4 3';}
  const marker=L.circleMarker(s.coords,mOpts).addTo(layers.ph1);
  marker.bindPopup(stationPopup(s),{maxWidth:290});
  marker.bindTooltip(s.proposed?s.name+' *':s.name,
    {permanent:true,direction:s.dir,offset:s.tier>=3?[12,0]:[9,0],className:'station-label'});
});

