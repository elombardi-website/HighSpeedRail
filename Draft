<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Southern Ontario HSR + Project Alto</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
@font-face { font-family:'PPWatch'; src:url('https://cdn.prod.website-files.com/697130eda1bfecc9f848bc06/6974407204552b8b69ef3fd8_PPWatch-Bold.woff2') format('woff2'); font-weight:700; }
@font-face { font-family:'PPWatch'; src:url('https://cdn.prod.website-files.com/697130eda1bfecc9f848bc06/69744072f10e6dc1e3a094ac_PPWatch-Black.woff2') format('woff2'); font-weight:900; }
@font-face { font-family:'PPPangramSans'; src:url('https://cdn.prod.website-files.com/697130eda1bfecc9f848bc06/69744123431f97eb3c3531a3_PPPangramSans-Regular.woff2') format('woff2'); font-weight:400; }
@font-face { font-family:'PPPangramSans'; src:url('https://cdn.prod.website-files.com/697130eda1bfecc9f848bc06/69744123407467774b52f691_PPPangramSans-Medium.woff2') format('woff2'); font-weight:500; }
@font-face { font-family:'PPPangramSans'; src:url('https://cdn.prod.website-files.com/697130eda1bfecc9f848bc06/697441235bf60318196d5fdf_PPPangramSans-Bold.woff2') format('woff2'); font-weight:700; }

:root {
  --ph1:    #E81E25;
  --ph2:    #2D2D2D;
  --alto:   #1A6FA8;
  --bg:     #F2F4F7;
  --black:  #101010;
  --grey:   #2D2D2D;
  --border: #DFE1E4;
  --amber:  #C27B0A;
}

* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'PPPangramSans',Arial,sans-serif; font-weight:400; background:#d4dde8; }
#map { width:100vw; height:100vh; }

/* ── Panel base ────────────────────────────────────────────── */
.panel {
  position:absolute; z-index:1000;
  background:rgba(242,244,247,0.97); border:1px solid var(--border);
  border-radius:10px; padding:12px 16px;
  box-shadow:0 2px 14px rgba(0,0,0,0.13);
}
.panel h1 { font-family:'PPWatch',Impact,sans-serif; font-weight:700; font-size:18px; color:var(--black); letter-spacing:.01em; margin-bottom:4px; line-height:1.1; text-transform:uppercase; }
.panel p  { font-size:11px; color:#888; font-weight:400; }
.lbl { font-family:'PPPangramSans',Arial,sans-serif; font-weight:700; font-size:9px; text-transform:uppercase; letter-spacing:.1em; color:#999; }

/* ── Collapsible panels ────────────────────────────────────── */
.panel-header {
  display:flex; align-items:center; justify-content:space-between;
  cursor:pointer; user-select:none; -webkit-tap-highlight-color:transparent;
}
.panel-chevron { font-size:13px; color:#aaa; transition:transform .2s; margin-left:8px; line-height:1; flex-shrink:0; }
.panel.collapsed .panel-chevron { transform:rotate(-90deg); }
.panel.collapsed .panel-body { display:none; }
.panel-body { margin-top:8px; }

/* ── Toggle switch ─────────────────────────────────────────── */
.toggle-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; font-size:12px; color:var(--grey); font-weight:500; gap:10px; }
.tog { position:relative; width:34px; height:18px; flex-shrink:0; }
.tog input { opacity:0; width:0; height:0; }
.sl { position:absolute; inset:0; background:#ccc; border-radius:18px; cursor:pointer; transition:.2s; }
.sl:before { content:''; position:absolute; width:14px; height:14px; left:2px; top:2px; background:#fff; border-radius:50%; transition:.2s; }
input:checked+.sl { background:var(--ph1); }
input:checked+.sl:before { transform:translateX(16px); }

/* ── Legend ────────────────────────────────────────────────── */
.legend { bottom:20px; left:14px; max-width:285px; }
.ls { margin-bottom:12px; }
.lr { display:flex; align-items:center; gap:9px; margin-bottom:6px; font-size:11px; color:var(--grey); line-height:1.3; font-weight:400; }
.ll { width:26px; height:5px; border-radius:3px; flex-shrink:0; }
.ld { width:13px; height:13px; border-radius:50%; border:2px solid rgba(0,0,0,.22); flex-shrink:0; }

/* ── Leaflet popup ─────────────────────────────────────────── */
.leaflet-popup-content-wrapper {
  background:rgba(242,244,247,0.98) !important; border:1px solid var(--border) !important;
  border-radius:10px !important; box-shadow:0 6px 24px rgba(0,0,0,.16) !important; color:var(--grey) !important;
}
.leaflet-popup-tip { background:rgba(242,244,247,0.98) !important; }
.leaflet-popup-content { margin:14px 18px !important; min-width:220px; font-family:'PPPangramSans',Arial,sans-serif; }

.pu-title { font-family:'PPWatch',Impact,sans-serif; font-weight:700; font-size:17px; color:var(--black); text-transform:uppercase; letter-spacing:.02em; line-height:1.1; margin-bottom:2px; }
.pu-sub   { font-weight:700; font-size:9px; color:#999; text-transform:uppercase; letter-spacing:.09em; margin-bottom:10px; }
.pu-section { font-weight:700; font-size:9px; text-transform:uppercase; letter-spacing:.09em; color:#999; margin:10px 0 6px; border-top:1px solid var(--border); padding-top:8px; }
.pu-row { display:flex; justify-content:space-between; align-items:baseline; gap:16px; margin-bottom:5px; font-size:12px; }
.pu-row .k { color:#888; font-weight:400; flex-shrink:0; }
.pu-row .v { color:var(--black); font-weight:700; text-align:right; font-size:13px; white-space:nowrap; }
.pu-row .v.sm { font-size:11px; color:#555; font-weight:400; }
.pu-via { font-size:9px; color:#bbb; font-style:italic; text-align:right; margin:-3px 0 5px; }

.seg-time { display:grid; grid-template-columns:1fr 1fr; gap:4px; margin-bottom:6px; }
.seg-time .lbl { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#888; }
.seg-time .val { font-size:14px; font-weight:700; }
.seg-time .val.exp { color:var(--ph1); }
.seg-time .val.reg { color:#5A5F68; }
.seg-time .subnote { font-size:10px; color:#aaa; font-style:italic; grid-column:1/-1; margin-top:1px; }

.pu-note  { font-size:10px; color:#aaa; font-style:italic; margin:-2px 0 6px; line-height:1.4; }
.pu-badge { display:inline-block; font-weight:700; font-size:9px; padding:2px 9px; border-radius:12px; margin-top:8px; letter-spacing:.06em; text-transform:uppercase; margin-right:4px; }
.pu-proposed { font-weight:700; font-size:9px; letter-spacing:.06em; text-transform:uppercase; color:#854d0e; background:#fef9c3; border:1px solid #fde047; border-radius:6px; padding:2px 8px; display:inline-block; margin-bottom:8px; }

/* ── Station / Alto labels ─────────────────────────────────── */
.station-label {
  background:transparent !important; border:none !important; box-shadow:none !important;
  font-family:'PPPangramSans',Arial,sans-serif !important; font-weight:700 !important;
  font-size:12px !important; color:var(--black) !important; white-space:nowrap; pointer-events:none;
  text-shadow:0 1px 4px rgba(242,244,247,.99),0 0 12px rgba(242,244,247,.95) !important;
}
.station-label::before { display:none !important; }
.alto-label {
  background:transparent !important; border:none !important; box-shadow:none !important;
  font-family:'PPPangramSans',Arial,sans-serif !important; font-weight:500 !important;
  font-size:11px !important; font-style:italic; color:var(--alto) !important; white-space:nowrap; pointer-events:none;
  text-shadow:0 1px 3px rgba(242,244,247,.99),0 0 10px rgba(242,244,247,.95) !important;
}
.alto-label::before { display:none !important; }

/* ── Speed info box ────────────────────────────────────────── */
.info-box {
  background:rgba(242,244,247,0.96); border:1px solid var(--border);
  border-radius:10px; padding:11px 15px; font-family:'PPPangramSans',Arial,sans-serif;
  font-size:11px; color:#444; box-shadow:0 2px 12px rgba(0,0,0,.1);
}

/* ── Mobile ────────────────────────────────────────────────── */
@media (max-width:639px) {
  .panel h1 { font-size:15px; }
  .panel p  { font-size:10px; }

  /* Wider touch targets */
  .tog { width:40px; height:22px; }
  .sl:before { width:18px; height:18px; }
  input:checked+.sl:before { transform:translateX(18px); }
  .toggle-row { font-size:13px; }

  /* Constrain panel widths to viewport */
  #layersPanel { min-width:unset !important; max-width:calc(100vw - 28px); }
  .legend      { max-width:calc(100vw - 28px) !important; }

  /* Hide speed info — too much on small screens */
  .info-box { display:none !important; }
}
</style>
</head>
<body>

<!-- Title panel -->
<div class="panel" style="top:14px;left:14px">
  <h1>Southern Ontario HSR<br>+ Project Alto</h1>
  <p>Proposed network · express journey times</p>
</div>

<!-- Layers panel -->
<div class="panel" id="layersPanel" style="top:14px;right:14px;min-width:220px">
  <div class="panel-header" onclick="togglePanel('layersPanel')">
    <h3 class="lbl" style="display:block">Layers</h3>
    <span class="panel-chevron">▾</span>
  </div>
  <div class="panel-body">
    <div class="toggle-row"><span>Phase 1 — Spine (Windsor–Oshawa)</span>
      <label class="tog"><input type="checkbox" checked onchange="toggleLayer('ph1',this.checked)"><span class="sl"></span></label></div>
    <div class="toggle-row"><span>Phase 2 — Branches</span>
      <label class="tog"><input type="checkbox" checked onchange="toggleLayer('ph2',this.checked)"><span class="sl"></span></label></div>
    <div class="toggle-row"><span>Project Alto Corridor</span>
      <label class="tog"><input type="checkbox" checked onchange="toggleLayer('alto',this.checked)"><span class="sl"></span></label></div>
    <div style="border-top:1px solid var(--border);margin-top:6px;padding-top:10px">
      <h3 class="lbl" style="display:block;margin-bottom:6px">Tile Style</h3>
      <select onchange="switchTiles(this.value)" style="width:100%;font-family:'PPPangramSans',Arial,sans-serif;font-size:12px;padding:5px 8px;border:1px solid rgba(0,0,0,.14);border-radius:6px;background:#fff;color:#333;cursor:pointer">
        <option value="voyager">Voyager (terrain + labels)</option>
        <option value="positron">Positron (minimal light)</option>
        <option value="dark">Dark (high contrast)</option>
        <option value="topo">OpenTopoMap (topographic)</option>
      </select>
    </div>
  </div>
</div>

<!-- Legend panel -->
<div class="panel legend" id="legendPanel" style="bottom:20px;left:14px">
  <div class="panel-header" onclick="togglePanel('legendPanel')">
    <h3 class="lbl" style="display:block">Legend</h3>
    <span class="panel-chevron">▾</span>
  </div>
  <div class="panel-body">
    <div class="ls" style="margin-top:4px">
      <h3 class="lbl" style="display:block;margin-bottom:9px">Phase 1 — Spine</h3>
      <div class="lr"><div class="ll" style="background:#E81E25"></div>Windsor – Chatham – London – KW – Pearson – Toronto – Oshawa</div>
    </div>
    <div class="ls">
      <h3 class="lbl" style="display:block;margin-bottom:9px">Phase 2 — Branches</h3>
      <div class="lr"><div class="ll" style="background:#2D2D2D"></div>Toronto – Hamilton – Niagara Falls</div>
      <div class="lr"><div class="ll" style="background:#2D2D2D"></div>Pearson–Hamilton · Hamilton–KW · Pearson–Barrie</div>
    </div>
    <div class="ls">
      <h3 class="lbl" style="display:block;margin-bottom:9px">Project Alto <span style="font-weight:400;font-style:italic;color:#bbb">(federal)</span></h3>
      <div class="lr"><div class="ll" style="background:#1A6FA8;opacity:0.75"></div>Toronto – Oshawa – Peterborough – Ottawa</div>
    </div>
    <div style="border-top:1px solid var(--border);padding-top:10px">
      <h3 class="lbl" style="display:block;margin-bottom:8px">Station Tiers</h3>
      <div class="lr"><div class="ld" style="background:#d4a017;border-color:#a07010"></div>Tier 4 · Pearson, Hamilton (4 connections)</div>
      <div class="lr"><div class="ld" style="background:#1d6fa4;border-color:#0d4d8c"></div>Tier 3 · Toronto, Kitchener, Oshawa (2–3)</div>
      <div class="lr"><div class="ld" style="background:#6b7280;border-color:#4b5563"></div>Regional / terminus (1–2 connections)</div>
    </div>
    <div style="border-top:1px solid var(--border);margin-top:8px;padding-top:6px;font-size:10px;color:#999">
      Times = ⚡ express via natural routing.<br>
      "via X" shown where route passes through a hub.<br>
      * Oshawa = proposed new station.
    </div>
  </div>
</div>

<div id="map"></div>

<script>
const tileSets = {
  voyager:  'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
  positron: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
  dark:     'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
  topo:     'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
};
const map = L.map('map',{center:[44.0,-78.8],zoom:7,zoomControl:false});
L.control.zoom({position:'bottomright'}).addTo(map);
let currentTile = L.tileLayer(tileSets.voyager,{attribution:'© OpenStreetMap contributors © CARTO',subdomains:'abcd',maxZoom:15}).addTo(map);
function switchTiles(key) {
  map.removeLayer(currentTile);
  currentTile = L.tileLayer(tileSets[key],{attribution:'© OpenStreetMap contributors © CARTO',subdomains:key==='topo'?'abc':'abcd',maxZoom:15}).addTo(map);
}

const layers = {ph1:L.layerGroup(),ph2:L.layerGroup(),alto:L.layerGroup()};
Object.values(layers).forEach(l=>l.addTo(map));
function toggleLayer(name,on){ on?layers[name].addTo(map):map.removeLayer(layers[name]); }

// ── Panel collapse ────────────────────────────────────────────
function togglePanel(id) {
  document.getElementById(id).classList.toggle('collapsed');
}
// Auto-collapse all panels on mobile
if (window.innerWidth < 640) {
  ['layersPanel','legendPanel'].forEach(id => {
    document.getElementById(id).classList.add('collapsed');
  });
}

const PH1='#E81E25', PH2='#2D2D2D', ALTO='#1A6FA8';

const C = {
  windsor:[42.317,-83.026], chatham:[42.404,-82.191], london:[42.984,-81.243],
  kitchener:[43.451,-80.492], pearson:[43.677,-79.631], toronto:[43.645,-79.380],
  oshawa:[43.897,-78.866], hamilton:[43.255,-79.869], niagara:[43.090,-79.081],
  barrie:[44.389,-79.690], peterborough:[44.300,-78.320], ottawa:[45.421,-75.697],
};

// ── Helpers ───────────────────────────────────────────────────
const sec  = t => `<div class="pu-section">${t}</div>`;
const note = t => `<div class="pu-note">${t}</div>`;
const bdg  = (t,bg,col,bdr) => `<span class="pu-badge" style="background:${bg};color:${col};border:1px solid ${bdr}">${t}</span>`;

function tRow(dest, time) {
  return `<div class="pu-row"><span class="k">${dest}</span><span class="v">${time}</span></div>`;
}

// ── Segments ──────────────────────────────────────────────────
// Segment times (express):
//   Windsor→Chatham: 20m  Chatham→London: 25m  London→KW: 27m
//   KW→Pearson: 26m  Pearson→Toronto: 12m  Toronto→Oshawa: 24m
//   Toronto→Hamilton: 20m  Hamilton→Niagara: 28m
//   KW→Hamilton: 18m  Pearson→Hamilton: 21m  Pearson→Barrie: 31m

const segments = [
  {phase:'ph1', name:'Windsor → Chatham',       from:C.windsor,  to:C.chatham,   km:80,  expAvg:235, expMins:20, regAvg:175, regMins:25, regStops:1, note:'Regional calls at intermediate stop.'},
  {phase:'ph1', name:'Chatham → London',        from:C.chatham,  to:C.london,    km:100, expAvg:240, expMins:25, regAvg:185, regMins:31, regStops:0, note:'Open corridor, flat terrain.'},
  {phase:'ph1', name:'London → Kitchener',      from:C.london,   to:C.kitchener, km:110, expAvg:245, expMins:27, regAvg:190, regMins:34, regStops:1, note:'Regional calls at Woodstock.'},
  {phase:'ph1', name:'Kitchener → Pearson',     from:C.kitchener,to:C.pearson,   km:85,  expAvg:200, expMins:26, regAvg:165, regMins:32, regStops:1, note:'Regional calls at Brampton/Mississauga.'},
  {phase:'ph1', name:'Pearson → Toronto Union', from:C.pearson,  to:C.toronto,   km:30,  expAvg:150, expMins:12, regAvg:130, regMins:14, regStops:0, note:'Urban grade-separated approach.'},
  {phase:'ph1', name:'Toronto Union → Oshawa',  from:C.toronto,  to:C.oshawa,    km:65,  expAvg:160, expMins:24, regAvg:140, regMins:30, regStops:1, note:'Regional calls at Pickering/Ajax.'},
  {phase:'ph2', name:'Toronto → Hamilton',       from:C.toronto,  to:C.hamilton,  km:70,  expAvg:210, expMins:20, regAvg:165, regMins:25, regStops:1, note:'Regional calls at Oakville/Burlington.'},
  {phase:'ph2', name:'Hamilton → Niagara Falls', from:C.hamilton, to:C.niagara,   km:85,  expAvg:180, expMins:28, regAvg:145, regMins:35, regStops:1, note:'Regional calls at St. Catharines.'},
  {phase:'ph2', name:'Pearson → Hamilton',       from:C.pearson,  to:C.hamilton,  km:65,  expAvg:190, expMins:21, regAvg:150, regMins:26, regStops:0, note:'No intermediate stops.'},
  {phase:'ph2', name:'Hamilton → Kitchener',     from:C.hamilton, to:C.kitchener, km:60,  expAvg:205, expMins:18, regAvg:165, regMins:22, regStops:0, note:'Completes GTHA triangle.'},
  {phase:'ph2', name:'Pearson → Barrie',         from:C.pearson,  to:C.barrie,    km:115, expAvg:220, expMins:31, regAvg:180, regMins:38, regStops:1, note:'Regional calls at Bradford/Innisfil.'},
];

segments.forEach(seg => {
  const col = seg.phase==='ph1' ? PH1 : PH2;
  L.polyline([seg.from,seg.to],{color:col,weight:12,opacity:0.15,smoothFactor:1}).addTo(layers[seg.phase]);
  L.polyline([seg.from,seg.to],{color:col,weight:5,opacity:0.93,smoothFactor:1})
    .bindPopup(`
      <div class="pu-title">${seg.name}</div>
      <div class="pu-sub">${seg.km} km · click a station for full journey times</div>
      ${sec('Journey times — this segment')}
      <div class="seg-time">
        <div><div class="lbl">⚡ Express</div><div class="val exp">${seg.expMins} min</div></div>
        <div><div class="lbl">◎ Regional</div><div class="val reg">${seg.regMins} min</div></div>
        <div class="subnote">${seg.regStops} intermediate stop${seg.regStops!==1?'s':''} on regional · ~4 min each · ${seg.note}</div>
      </div>`,{maxWidth:300}).addTo(layers[seg.phase]);
});

// ── Alto ──────────────────────────────────────────────────────
L.polyline([C.toronto,C.oshawa,C.peterborough,C.ottawa],{color:ALTO,weight:12,opacity:0.12}).addTo(layers.alto);
L.polyline([C.toronto,C.oshawa,C.peterborough,C.ottawa],{color:ALTO,weight:4,opacity:0.72,dashArray:'12 5'})
  .bindPopup(`
    <div class="pu-title">Project Alto</div>
    <div class="pu-sub">Federal HSR · Toronto – Ottawa</div>
    <div class="seg-time" style="margin-top:10px">
      <div><div class="lbl">⚡ Express</div></div>
      <div><div class="lbl">◎ Regional</div></div>
    </div>
    ${tRow('Toronto → Ottawa','2h 05m / 2h 45m',null)}
    ${tRow('Toronto → Peterborough','~31m / ~43m',null)}
    ${note('Phase 1 construction: Ottawa–Montréal, 2029. Alignment via Peterborough — inland, not lakeshore.')}`,{maxWidth:290})
  .addTo(layers.alto);

[{coords:C.peterborough,name:'Peterborough',dir:'right',
  times:[['From Toronto','~31m',null],['From Oshawa','~20m',null],['From Ottawa','~1h 25m',null]],
  note:'Alto corridor stop. Inland alignment between Oshawa and Ottawa.'},
 {coords:C.ottawa,name:'Ottawa →',dir:'right',
  times:[['From Toronto','~2h 05m',null],['From Oshawa','~1h 25m',null],['From Peterborough','~1h 05m',null]],
  note:'Eastern map limit. Alto continues to Montréal & Québec City.'},
].forEach(s=>{
  const timesHtml = s.times.map(([d,t,v])=>tRow(d,t,v)).join('');
  L.circleMarker(s.coords,{radius:10,fillColor:ALTO,color:'#fff',weight:2.5,opacity:1,fillOpacity:1})
    .bindPopup(`
      <div class="pu-title">${s.name.replace(' →','')}</div>
      <div class="pu-sub">Project Alto Station</div>
      ${note(s.note)}
      ${sec('⚡ Express journey times')}${timesHtml}
      ${bdg('Project Alto','#dbeafe','#1A6FA8','#93c5fd')}`,{maxWidth:260})
    .addTo(layers.alto);
  L.tooltip({permanent:true,direction:s.dir,className:'alto-label',offset:[9,0]})
    .setContent(s.name).setLatLng(s.coords).addTo(layers.alto);
});

// ── STATIONS ──────────────────────────────────────────────────
// All times are ⚡ express (fastest natural routing through hubs).
// Segment reference:
//   Windsor→Chatham: 20m  Chatham→London: 25m  London→KW: 27m
//   KW→Pearson: 26m  Pearson→Toronto: 12m  Toronto→Oshawa: 24m
//   Toronto→Hamilton: 20m  Hamilton→Niagara: 28m
//   KW→Hamilton: 18m  Pearson→Hamilton: 21m  Pearson→Barrie: 31m

const stations = [

  // ── PEARSON (4 connections) ──────────────────────────────────
  {name:'Pearson International', coords:C.pearson, tier:4, r:14, dir:'right', proposed:false,
   connections:4, sub:'Hub Tier 4 · 4 Connections',
   serves:['Windsor–Oshawa spine','Hamilton branch','Barrie spur','Toronto Union stub'],
   note:'Only Tier 4 node. Integrated airport terminal.',
   chatham:false,
   times:[
     ['Toronto Union',    '12m',   null],
     ['Kitchener',        '26m',   null],
     ['Hamilton',         '21m',   'Pearson–Hamilton branch'],
     ['Barrie',           '31m',   null],
     ['Oshawa',           '36m',   'Toronto'],
     ['London',           '53m',   null],
     ['Niagara Falls',    '49m',   'Hamilton'],
     ['Windsor',          '1h 38m',null],
